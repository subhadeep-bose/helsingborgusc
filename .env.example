# Supabase — required
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Cloudflare Turnstile CAPTCHA — required for registration
VITE_TURNSTILE_SITE_KEY=your-turnstile-site-key

# CricAPI — optional, enables live India cricket scores (https://cricapi.com)
VITE_CRICAPI_KEY=your-cricapi-key
